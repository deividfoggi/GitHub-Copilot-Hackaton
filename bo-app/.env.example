# URL base do app de Boletim de Ocorrência (usada pelo agente Foundry)
BO_API_URL=http://localhost:8000

# Configuração do Microsoft Foundry (Etapa 3 do workshop)
# Endpoint do projeto Foundry, ex.: https://<seu-projeto>.services.ai.azure.com/api/projects/<projeto>
FOUNDRY_PROJECT_ENDPOINT=
# Nome do modelo implantado no projeto, ex.: gpt-4o-mini
FOUNDRY_MODEL_DEPLOYMENT=gpt-4o-mini
